# ──────────────────────────────────────────────────────
#  Configurações da API GestãoClick — Locvix
#  Copie este arquivo para .env e preencha os valores.
# ──────────────────────────────────────────────────────

# Credenciais da API
# Onde encontrar: dentro do ERP GestãoClick
#   Configurações → Integrações → API → Access Token / Secret Token
GCK_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
GCK_SECRET_TOKEN=SEU_SECRET_TOKEN_AQUI

# Período de análise (opcional — padrão: ano atual)
# Formato: DD/MM/AAAA
GCK_DATA_INI=01/01/2026
GCK_DATA_FIM=31/12/2026
